{
  "expo": {
    "name": "Sticks",
    "slug": "sticks",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#101511"
    },
    "ios": {
      "bundleIdentifier": "com.sticks.golf",
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": "AIzaSyB1Ez8b5jBOTcUSXzEvpD3N9UUFIohCR4Y"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Sticks uses your GPS location as a golf rangefinder to calculate distance to the pin, front, center, and back of the green during your round.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Sticks uses background GPS to keep calculating distances and tracking your shot trail even with the screen locked during a round.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["location"]
      }
    },
    "android": {
      "package": "com.sticks.golf",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyB1Ez8b5jBOTcUSXzEvpD3N9UUFIohCR4Y"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#101511"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-location",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "scheme": "com.sticks.golf",
    "extra": {
      "eas": {
        "projectId": "b58bb85f-75ee-4b4d-b535-1b72ed1104e5"
      }
    }
  }
}
